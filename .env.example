APP_NAME="CommunityOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://communityos.test

# Wildcard subdomain used for tenant (society) resolution e.g. {society}.communityos.test
APP_CENTRAL_DOMAIN=communityos.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database (MySQL 8 — shared database, tenant isolation via society_id column)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=communityos
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Cache / Session / Queue (Redis backed in production)
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Use "redis" in production (predis client is installed; no PHP extension required)
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=communityos

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@communityos.io"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# AWS S3 (document / image / invoice storage)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

# ---------------------------------------------------------------------------
# SMS gateway (MSG91 / Twilio)
# ---------------------------------------------------------------------------
SMS_DRIVER=log
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CMNTYOS
MSG91_ROUTE=4
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---------------------------------------------------------------------------
# WhatsApp Cloud API
# ---------------------------------------------------------------------------
WHATSAPP_DRIVER=log
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@communityos.io"

# ---------------------------------------------------------------------------
# Payment gateways
# ---------------------------------------------------------------------------
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Multi-tenancy
# ---------------------------------------------------------------------------
TENANCY_RESOLVER=auth        # auth | subdomain | header
TENANCY_HEADER=X-Society-Id

# Sanctum stateful domains for SPA / first-party API
SANCTUM_STATEFUL_DOMAINS=communityos.test,localhost,127.0.0.1

VITE_APP_NAME="${APP_NAME}"
